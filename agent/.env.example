# LLM (OpenAI GPT-5.2 with vision)
OPENAI_API_KEY=

# Database (PostgreSQL + pgvector RAG)
DATABASE_URL=postgresql://candidai:candidai@localhost:5432/candidai

# Postgres (for docker-compose)
POSTGRES_PASSWORD=candidai

# STT (Deepgram)
DEEPGRAM_API_KEY=

# TTS (Edge TTS - free Microsoft neural, no API key needed)
# Voice options: en-US-AriaNeural, en-US-GuyNeural, en-GB-RyanNeural, etc.
EDGE_TTS_VOICE=en-US-AriaNeural

# Video/Stream
STREAM_API_KEY=
STREAM_API_SECRET=

# RAG options
CANDIDAI_RAG_FORCE_REINDEX=0

# Media modes
CANDIDAI_SUBSCRIBE_VIDEO=1
CANDIDAI_ENABLE_POSE=1
CANDIDAI_USE_SMART_TURN=0
